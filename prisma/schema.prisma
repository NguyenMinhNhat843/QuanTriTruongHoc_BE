// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 1. Định nghĩa Enum cho các loại quyền
enum RoleType {
  ADMIN
  STAFF
  STUDENT
}

model User {
  id        String    @id
  username  String    @unique
  password  String
  email     String?   @unique
  
  role      RoleType  @default(STAFF)
  
  fullName  String    @default("Unknow")
  gender    String?    @default("Unknow")
  phone     String?
  birthday  DateTime?
  address   String?
  isActive  Boolean   @default(true)
  avatarUrl String?
  
  staff     Staff?
  student   Student?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// --- PHÂN HỆ NHÂN SỰ ---
model Staff {
  id           String     @id
  staffCode    String     @unique // Mã nhân viên (VD: NV001)
  
  // Liên kết hệ thống
  user         User       @relation(fields: [userId], references: [id])
  userId       String     @unique
  
  // Liên kết tổ chức
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String

  position     String?    // Chức vụ: Trưởng khoa, Giảng viên...
  isTeaching   Boolean    @default(false) // Có tham gia giảng dạy không

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// --- PHÂN HỆ HỌC SINH ---
model Student {
  id           String        @id
  studentCode  String        @unique // Mã số học sinh (VD: HS2024001)
  citizenId    String?       @unique // Số CCCD
  
  // Thông tin nhập học
  enrollmentDate DateTime    @default(now())
  status       StudentStatus @default(STUDYING)

  // Liên kết hệ thống (Có thể null nếu học sinh chưa được cấp account)
  user         User?         @relation(fields: [userId], references: [id])
  userId       String?       @unique

  // Liên kết học thuật
  major        Major         @relation(fields: [majorId], references: [id]) // Ngành nghề
  majorId      String
  class        Class?        @relation(fields: [classId], references: [id]) // Lớp hoc
  classId      String?

  // Quan hệ khác
  grades       Grade[]      // Điểm số
  gradResults  GraduationResult[]   // Kết quả thi

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

enum StudentStatus {
  STUDYING    // Đang học
  DROPPED     // Thôi học
  SUSPENDED   // Bảo lưu
  GRADUATED   // Đã tốt nghiệp
}

// 1. Thêm Model Department
// Phòng ban / Khoa
model Department {
  id        String   @id
  code      String   @unique
  name      String   @unique
  staffs    Staff[]
  majors    Major[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Thêm Model Major - Ngành học / chuyên ngành
model Major {
  id           String     @id
  code         String     @unique
  name         String
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  students     Student[]
  classes      Class[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// 3. Thêm Model Class - Lớp học
model Class {
  id String @id @default(uuid())
  name      String    @unique // VD: CNTT-K24A
  major     Major     @relation(fields: [majorId], references: [id])
  majorId   String
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 4. Thêm Model Grade (Tạm thời để đơn giản để chạy được migrate)
model Grade {
  id        String  @id
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  score     Float?
  subject   String // Sau này mình tách Subject sau
}

// 5. Thêm Model GraduationResult
model GraduationResult {
  id        String  @id
  student   Student @relation(fields: [studentId], references: [id])
  studentId String
  status    String  // PASSED, FAILED...
}

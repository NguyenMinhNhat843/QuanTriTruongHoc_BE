
// ==========================
// 12. FINANCIAL SYSTEM (HỆ THỐNG TÀI CHÍNH)
// ==========================
// Hóa đơn tổng theo học kỳ
model FeeInvoice {
  id          Int              @id @default(autoincrement())
  
  studentId   Int
  student     Student          @relation(fields: [studentId], references: [id])
  
  semesterId  Int
  semester    Semester         @relation(fields: [semesterId], references: [id])
  
  totalAmount Float            // Tổng tiền phải đóng của cả kỳ
  
  // status: unpaid, partial, paid
  status      String           @default("unpaid")
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  items       FeeInvoiceItem[]

  @@map("fee_invoices")
}

// Chi tiết từng hạng mục trong hóa đơn (Từng môn học hoặc loại phí)
model FeeInvoiceItem {
  id            Int                 @id @default(autoincrement())
  studentId     Int?                

  name          String
  amount        Float               // Số tiền gốc của item này

  invoiceId     Int?
  invoice       FeeInvoice?          @relation(fields: [invoiceId], references: [id])
  
  // status: unpaid, partial, paid
  status        String              @default("unpaid")

  allocations   PaymentAllocation[]

  @@map("fee_invoice_items")
}

// Giao dịch thanh toán
model Payment {
  id            Int                 @id @default(autoincrement())
  
  studentId     Int
  student       Student             @relation(fields: [studentId], references: [id])
  
  totalPaid     Float               // Tổng tiền nộp trong lần giao dịch này
  paymentDate   DateTime            @default(now())
  
  method        PaymentMethod
  
  transactionRef String?            // Mã đối soát ngân hàng
  
  createdAt     DateTime            @default(now())

  allocations   PaymentAllocation[]

  @@map("payments")
}


// Bảng phân bổ (Gạch nợ)
// Kết nối số tiền từ 1 lần nộp (Payment) vào các hạng mục hóa đơn (InvoiceItem)
model PaymentAllocation {
  id               Int            @id @default(autoincrement())
  
  paymentId        Int
  payment          Payment        @relation(fields: [paymentId], references: [id])
  
  feeInvoiceItemId Int
  feeInvoiceItem   FeeInvoiceItem @relation(fields: [feeInvoiceItemId], references: [id])
  
  amount           Float          // Số tiền trích ra để đóng cho mục này
  
  allocatedAt      DateTime       @default(now())

  @@map("payment_allocations")
}

model Fee {
  id        Int   @id @default(autoincrement())
  name      String   // BHYT, CSV, ...

  createdAt DateTime @default(now())

  feeCatalogs FeeCatalog[]
}

model FeeCatalog {
  id        Int   @id @default(autoincrement())

  feeId     Int
  fee       Fee      @relation(fields: [feeId], references: [id])

  // phạm vi
  majorId   Int?
  batchId   Int?
  semester  Int?

  // global hay không
  isGlobal  Boolean  @default(false)

  amount    Int

  createdAt DateTime @default(now())
}

model CreditPrice {
  id        Int   @id @default(autoincrement())

  // phạm vi áp dụng
  majorId   Int?
  major     Major?   @relation(fields: [majorId], references: [id])

  batchId   Int?
  batch     Batch?   @relation(fields: [batchId], references: [id])

  semester  Int?     // optional (nếu sau này có khác theo kỳ)

  isGlobal  Boolean  @default(false)

  // giá tiền / tín chỉ
  price     Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CourseOfferStatus {
  planned
  open
  closed
  cancelled
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ==========================
// 8. ClassSubject (Bảng trung gian giữa môn học và lớp học --> để phân giáo viên)
// ==========================
model CourseOffer {
  id                Int       @id @default(autoincrement())
  teacherId         Int?
  teacher           Staff?    @relation(fields: [teacherId], references: [id])
  subjectId         Int
  subject           Subject   @relation(fields: [subjectId], references: [id])
  classId           Int?
  baseClass         Class?    @relation(fields: [classId], references: [id])
  semesterId        Int
  semester          Semester  @relation(fields: [semesterId], references: [id])
  maxStudents       Int?       @default(40)
  currentStudents   Int?       @default(0) // Cần logic update khi có sinh viên đăng ký thành công
  
  // planned, open, closed, cancelled
  status            CourseOfferStatus? @default(planned)
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt  

  // Quan hệ
  registrations     CourseRegistration[]
  courseSchedules   CourseSchedule[]

  @@unique([subjectId, classId])
  @@index([subjectId, semesterId])
  @@index([teacherId])
  @@index([semesterId])
  @@index([classId])
  @@map("course_offers")
}

// ==========================
// Điểm của 1 học sinh của 1 classSubject
// ==========================
model CourseRegistration {
  id             Int         @id @default(autoincrement())
  
  studentId      Int
  student        Student     @relation(fields: [studentId], references: [id])
  
  courseOfferId  Int
  courseOffer    CourseOffer @relation(fields: [courseOfferId], references: [id])
  
  kttx1           Float?
  kttx2           Float?
  kttx3           Float?
  ktdk1           Float?
  ktdk2           Float?
  ktdk3           Float?
  ktdk4           Float?
  diemTB          Float?
  diemKiemTra1    Float?
  diemKiemTra2    Float?
  diemTongKet1    Float?
  diemTongKet2    Float?
  rating          String?

  note           String?     @db.Text
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([studentId, courseOfferId])
  @@map("course_registrations")
}

// ==========================
// 10. COURSE_SCHEDULES (THỜI KHÓA BIỂU CHI TIẾT)
// ==========================
model CourseSchedule {
  id            Int         @id @default(autoincrement())
  
  courseOfferId Int
  courseOffer   CourseOffer @relation(fields: [courseOfferId], references: [id])
  
  dayOfWeek     DayOfWeek   // 2 -> 8 (Thứ 2 đến Chủ Nhật)
  
  startTime     DateTime    @db.Time
  endTime       DateTime    @db.Time
  
  roomId        Int?     // Có thể ghi đè phòng học nếu buổi đó học phòng khác
  room          Room?       @relation(fields: [roomId], references: [id])

  createdAt     DateTime    @default(now())

  @@unique([courseOfferId, dayOfWeek, startTime])
  @@map("course_schedules")
}

model TeacherSubject {
  id        Int @id @default(autoincrement())

  teacherId Int
  subjectId Int

  teacher   Staff   @relation(fields: [teacherId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

// ==========================
// 1. DEPARTMENTS (PHÒNG BAN / KHOA)
// ==========================
model Department {
  id                  Int       @id @default(autoincrement())
  deptCode            String    @unique
  deptName            String
  description         String?   @db.Text

  // Trưởng khoa (Nối đến bảng Staff)
  headOfDepartmentId  Int?
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Quan hệ
  majors              Major[]

  @@map("departments")
}

// ==========================
// 2. MAJORS (NGÀNH ĐÀO TẠO)
// ==========================
model Major {
  id              Int        @id @default(autoincrement())
  majorCode       String     @unique
  majorName       String
  
  // Thuộc về phòng ban/khoa nào
  deptId          Int
  department      Department @relation(fields: [deptId], references: [id])
  
  durationYears   String?    // Ví dụ: "2.5 năm" hoặc "3 năm"
  totalCredits    Int        @default(0)
  
  description     String?    @db.Text
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Quan hệ
  classes         Class[]
  curriculumn     Curriculum[]
  students        Student[]
  batches         Batch[]
  creditPrices    CreditPrice[] 

  @@map("majors")
}

// ==========================
// 2.5 BATCHES (KHÓA ĐÀO TẠO)
// ==========================
model Batch {
  id          Int      @id @default(autoincrement())
  batchCode   String   @unique // Ví dụ: K1, K26, 2026
  batchName   String   // Ví dụ: Khóa 1, Khóa 2026
  
  startYear   Int      // Năm bắt đầu (2026)
  endYear     Int      // Năm kết thúc dự kiến (2030)

  description String?

  majorId     Int
  major       Major    @relation(fields: [majorId], references: [id])

  curriculumId  Int?    @unique
  curriculum    Curriculum? @relation(fields: [curriculumId], references: [id])

  // Trạng thái khóa học: ADMISSION (đang tuyển), ACTIVE (đang học), GRADUATED (đã tốt nghiệp)
  status      String   @default("ACTIVE")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Quan hệ: Một khóa có nhiều lớp
  classes     Class[]
  students    Student[]
  admissionItems    AdmissionItem[]
  creditPrices CreditPrice[] 

  @@map("batches")
}

// ==========================
// 3. CLASSES (LỚP DANH NGHĨA)
// ==========================
model Class {
  id            Int      @id @default(autoincrement())
  classCode     String   @unique // CNTTK1A
  className     String
  
  // Thuộc về 1 ngành
  majorId       Int
  major         Major    @relation(fields: [majorId], references: [id])
  
  // Liên kết với Khóa đào tạo
  batchId       Int?
  batch         Batch?    @relation(fields: [batchId], references: [id])
  
  // Giáo viên chủ nhiệm
  formTeacherId Int?
  
  maxStudents   Int      @default(40)
  currentSize   Int      @default(0) // Nên có trường này để track sĩ số nhanh
  
  status        String   @default("active")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courseOffers  CourseOffer[]
  students      Student[] // Một lớp có nhiều học sinh

  @@map("classes")
}

// ==========================
// 4. SUBJECTS (MÔN HỌC)
// ==========================
model Subject {
  id            Int        @id @default(autoincrement())
  subjectCode   String     @unique
  subjectName   String
  
  credits       Int        @default(0)
  
  theoryHours   Int        @default(0)
  practiceHours Int        @default(0)
  
  isMandatory   Boolean    @default(true)
  
  description   String?    @db.Text
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // quan hệ
  curriculumnSubject  CurriculumSubject[]
  courseOffers        CourseOffer[]
  teacherSubjects     TeacherSubject[]

  @@map("subjects")
}

// ==========================
// 5. SEMESTERS (HỌC KỲ)
// ==========================
model Semester {
  id          Int      @id @default(autoincrement())
  name        String   // Ví dụ: HK1-2026, HK2-2026
  term        Int?       // Kỳ, ví dụ: 1, 2 nghĩa là Học kỳ 1 2 dùng để truy vấn dễ hơn
  year        Int?      // Năm học nào
  schoolYear  String?   // Ví dụ: 2025-2026
  
  startDate   DateTime @db.Date
  endDate     DateTime @db.Date
  
  isCurrent   Boolean  @default(false) // Đánh dấu học kỳ hiện tại để hệ thống lấy mặc định
  
  createdAt   DateTime @default(now())

  // quan hệ
  benefitPrograms     BenefitProgram[]
  courseOffers        CourseOffer[]
  feeInvoices         FeeInvoice[]

  // ràng buộc duy nhất
  @@unique([year, term], name: "unique_semester_term")
  @@map("semesters")
}


// ==========================
// ROOM (PHÒNG HỌC)
// ==========================
model Room {
  id        Int      @id @default(autoincrement())
  roomCode  String   @unique // Ví dụ: A1.102, LAB_IT_01
  type      String   // theory (lý thuyết), practice (thực hành), hall (hội trường)
  capacity  Int?     // Sức chứa (tùy chọn thêm để kiểm tra sĩ số lớp)
  building  String?  // Tòa nhà (ví dụ: Tòa A, Tòa B)
  
  createdAt DateTime @default(now())

  // Quan hệ
  courseSchedules CourseSchedule[]

  @@map("rooms")
}


// ==========================
// 6. CURRICULUMS (CHƯƠNG TRÌNH KHUNG)
// ==========================
model Curriculum {
  id              Int      @id @default(autoincrement())
  curriculumCode  String   @unique // Ví dụ: CTK-CNTT-2023
  curriculumName  String
  
  majorId         Int
  major           Major    @relation(fields: [majorId], references: [id])

  version         Int      @default(1) // Quản lý phiên bản để cập nhật CTK theo năm
  totalCredits    Int      @default(0)
  
  effectiveFrom   DateTime? @db.Date
  effectiveTo     DateTime? @db.Date
  
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Quan hệ 1-n với bảng trung gian
  curriculumSubjects CurriculumSubject[]
  batch               Batch?

  @@map("curriculums")
}

// ==========================
// 7. CURRICULUM_SUBJECTS (MÔN HỌC THUỘC CHƯƠNG TRÌNH)
// ==========================
model CurriculumSubject {
  id             Int        @id @default(autoincrement())
  
  curriculumId   Int
  curriculum     Curriculum @relation(fields: [curriculumId], references: [id])
  
  subjectId      Int
  subject        Subject    @relation(fields: [subjectId], references: [id])
  
  semesterNumber Int        // Học kỳ gợi ý (Học kỳ 1, 2, 3...)
  
  isMandatory    Boolean    @default(true) // môn bắt buộc hay tự chọn
  minGrade       Float      @default(5.0) // Điểm tối thiểu để qua môn (thường là 4 hoặc 5)
  
  createdAt      DateTime   @default(now())

  @@unique([curriculumId, subjectId]) // Một môn học không xuất hiện 2 lần trong 1 chương trình
  @@map("curriculum_subjects")
}
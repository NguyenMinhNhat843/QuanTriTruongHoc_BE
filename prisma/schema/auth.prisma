// ==========================
// USERS (AUTH + COMMON PROFILE)
// ==========================
model User {
  id            Int       @id @default(autoincrement())
  userId        String    @unique // Mã định danh ngoại (UUID hoặc NanoID)
  username      String    @unique
  passwordHash  String
  
  lastLoginAt   DateTime?
  
  role          RoleType
  isActive      Boolean   @default(true)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  // Quan hệ
  student       Student?
  staff         Staff?
  posts         Post[]

  @@map("users")
}

// ==========================
// STUDENTS: Hồ sơ học sinh
// ==========================
model Student {
  id             Int           @id @default(autoincrement())
  studentCode    String        @unique
  
  // Quan hệ 1-1 với User
  userId         Int?           @unique
  user           User?           @relation(fields: [userId], references: [id])

  // Thông tin hồ sơ
  email         String?         @unique
  fullName      String?
  gender        Boolean?        // true: male, false: female
  dob           DateTime?       @db.Date
  phone         String?         
  avatarUrl     String?
  address       String?
  identityNumber    String?     @unique // CCCD

  majorId         Int?           // Ngành           
  major         Major?           @relation(fields: [majorId], references: [id])

  batchId         Int?          // Khóa đào tạo
  batch         Batch?          @relation(fields: [batchId], references: [id])

  classId        Int?           // Lớp
  classCode     Class?           @relation(fields: [classId], references: [id])
  
  enrollmentDate DateTime?      @db.Date
  graduationDate DateTime?      @db.Date
  
  // status: 'pending' (Mới nộp), 'reviewing' (Đang xét), 
  // 'approved' (Đạt - Chờ tạo account), 'rejected' (Không đạt), 'studying' (Chính thức)
  status         StudentStatus  @default(studying)
  
  parentName     String?        
  parentPhone    String?
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // quan hệ
  benefitApplications BenefitApplication[]
  benefitAwards       BenefitAward[]
  courseRegistrations CourseRegistration[] 
  feeInvoices         FeeInvoice[]
  payments            Payment[]
  gradeEntries        GradeEntry[]
  grades              Grade[]

  @@map("students")
}

// ==========================
// STAFFS
// ==========================
model Staff {
  id                Int         @id @default(autoincrement())
  staffCode         String      @unique
  
  // Quan hệ 1-1 với User
  userId            Int         @unique
  user              User        @relation(fields: [userId], references: [id])
  
  // thông tin cá nhân
  email             String?     @unique
  fullName          String?
  gender            Boolean?    // true: male, false: female
  dob               DateTime?   @db.Date
  phone             String?    
  avatarUrl         String?
  address           String?
  identityNumber    String?     @unique // CCCD

  departmentId      Int?
  position          String?     // Ví dụ: Nhân viên kế toán, hiệu trưởng...
  
  hireDate          DateTime?   @db.Date
  contractType      String?     // full-time, part-time
  
  salaryCoefficient Float?      // Hệ số lương
  
 
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // quan hệ
  courseOffers      CourseOffer[]

  @@map("staffs")
}

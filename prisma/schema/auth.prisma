// ==========================
// USERS (AUTH + COMMON PROFILE)
// ==========================
model User {
  id            Int       @id @default(autoincrement())
  userId        String    @unique // Mã định danh ngoại (UUID hoặc NanoID)
  username      String    @unique
  passwordHash  String
  lastLoginAt   DateTime?
  role          RoleType
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  student       Student?
  staff         Staff?
  posts         Post[]

  @@map("users")
}

/* 
**  Student: Hồ sơ học sinh
*/
enum StudentStatus {
  approved   // Đã xác nhận nhập học, đợi đóng học phí nhập học
  studying   // Đã có tài khoản và đang theo học chính thức
  suspended  // Đang bảo lưu kết quả học tập hoặc bị đình chỉ tạm thời
  dropped    // Đã thôi học hoặc bỏ học giữa chừng
  expelled   // Bị buộc thôi học (do kỷ luật hoặc lý do đặc biệt)
  graduated  // Đã hoàn thành chương trình và tốt nghiệp
}

model Student {
  id              Int             @id @default(autoincrement())
  studentCode     String          @unique
  batchId         Int?            // Khóa đào tạo
  batch           Batch?          @relation(fields: [batchId], references: [id])
  classId         Int?            // Lớp
  class           Class?          @relation(fields: [classId], references: [id])
  enrollmentDate  DateTime?       @db.Date
  graduationDate  DateTime?       @db.Date
  status          StudentStatus   @default(studying)
  applicationId   Int?            @unique // Hồ sơ tuyển sinh
  application     Application?    @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  // Thông tin cá nhân
  userId          Int?            @unique
  user            User?           @relation(fields: [userId], references: [id])
  email           String?        
  fullName        String?
  gender          Boolean?        // true: male, false: female
  dob             DateTime?       @db.Date
  phone           String?         
  avatarUrl       String?
  address         String?
  identityNumber  String?         @unique // CCCD

  // Thông tin cha
  fatherName         String?
  fatherPhone        String?
  fatherCCCD         String?
  fatherYearOfBirth  Int?
  fatherJob          String?

  // Thông tin mẹ
  motherName         String?
  motherPhone        String?
  motherCCCD         String?
  motherYearOfBirth  Int?
  motherJob          String?

  // Thông tin người giám hộ
  guardianName        String?
  guardianRelationship String?      // Ông, Bà, Cô, Chú, Anh, Chị,...
  guardianPhone       String?
  guardianCCCD        String?
  guardianYearOfBirth Int?
  guardianJob         String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  benefitApplications BenefitApplication[]
  benefitAwards       BenefitAward[]
  courseRegistrations CourseRegistration[] 
  feeInvoices         FeeInvoice[]
  payments            Payment[]

  @@map("students")
}

// ==========================
// STAFFS
// ==========================
model Staff {
  id                Int         @id @default(autoincrement())
  staffCode         String      @unique
  userId            Int         @unique
  user              User        @relation(fields: [userId], references: [id])
  email             String?     @unique
  fullName          String?
  gender            Boolean?    // true: male, false: female
  dob               DateTime?   @db.Date
  phone             String?    
  avatarUrl         String?
  address           String?
  identityNumber    String?     @unique // CCCD
  departmentId      Int?
  position          String?     // Ví dụ: Nhân viên kế toán, hiệu trưởng...
  hireDate          DateTime?   @db.Date
  contractType      String?     // full-time, part-time
  salaryCoefficient Float?      // Hệ số lương
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  courseOffers      CourseOffer[]
  teacherSubjects   TeacherSubject[]

  @@map("staffs")
}


// ==========================
// 11. GRADING SYSTEM (HỆ THỐNG ĐIỂM)
// ==========================

// Cấu hình loại điểm (Ví dụ: Chuyên cần 10%, Giữa kỳ 30%, Cuối kỳ 60%)
model GradeComponent {
  id              Int          @id @default(autoincrement())
  name            String       // midterm, final, assignment...
  weight          Float?       // 0.1, 0.3, 0.6... // Bỏ field này

  subjectGrades   SubjectGradeWeight[]
  gradeEntries    GradeEntry[]

  @@map("grade_components")
}

// ==========================
// BẢNG TRUNG GIAN: CẤU HÌNH TỶ LỆ ĐIỂM CHO TỪNG MÔN HỌC
// ==========================
model SubjectGradeWeight {
  id               Int            @id @default(autoincrement())
  subjectId        Int
  subject          Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  gradeComponentId Int
  gradeComponent   GradeComponent @relation(fields: [gradeComponentId], references: [id], onDelete: Restrict)
  weight           Float          // Trọng số - ví dụ: 1, 2, 3
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  position         Int?           // Thứ tự hiển thị

  @@unique([subjectId, gradeComponentId]) // Ràng buộc: Một môn học không thể cấu hình trùng 1 loại điểm 2 lần
  @@map("subject_grade_weights")
}

enum GradeSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}
model GradeEntry {
  id                    Int                 @id @default(autoincrement())
  componentId           Int
  component             GradeComponent      @relation(fields: [componentId], references: [id])
  courseRegistrationId  Int?
  CourseRegistration    CourseRegistration? @relation(fields: [courseRegistrationId], references: [id])
  score                 Float?
  status                GradeSubmissionStatus?

  @@unique([componentId, courseRegistrationId]) // Một học sinh không thể có 2 điểm cùng loại trong 1 lớp
  @@map("grade_entries")
}
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["prismaSchemaFolder"]
  moduleFormat    = "cjs"
}


datasource db {
  provider = "postgresql"
}

// ==========================
// 1. ENUMS
// ==========================
enum RoleType {
  admin
  teacher
  student
  staff
}

enum StudentStatus {
  // --- GIAI ĐOẠN TUYỂN SINH (ADMISSION) ---
  pending    // Hồ sơ mới nộp, đang chờ kiểm tra thông tin
  reviewing  // Đang trong quá trình xét duyệt hồ sơ/điểm số
  approved   // Đã đạt tiêu chuẩn, chờ admin bấm cấp tài khoản (User)
  rejected   // Hồ sơ không đạt yêu cầu hoặc bị từ chối

  // --- GIAI ĐOẠN TRUNG GIAN (Quan trọng cho phân lớp) ---
  enrolled   // Đã xác nhận nhập học, nộp phí. API phân lớp sẽ quét những người này.

  // --- GIAI ĐOẠN HỌC TẬP (ACADEMIC) ---
  studying   // Đã có tài khoản và đang theo học chính thức
  suspended  // Đang bảo lưu kết quả học tập hoặc bị đình chỉ tạm thời
  dropped    // Đã thôi học hoặc bỏ học giữa chừng
  expelled   // Bị buộc thôi học (do kỷ luật hoặc lý do đặc biệt)

  // --- GIAI ĐOẠN KẾT THÚC (GRADUATION) ---
  graduated  // Đã hoàn thành chương trình và tốt nghiệp
}

enum PaymentMethod {
  cash
  bank_transfer
  credit_card
  e_wallet
}

enum ApplycationAdmissionStatus {
  PENDING
  QUALIFIED
  ADMITTED
  REJECTED
  ENROLLED
}

enum AdmissionStatus {
  OPEN 
  CLOSE 
  ARCHIVED
}